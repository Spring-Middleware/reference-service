		{
			"name": "Get Catalog by ID with expansion",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.products && jsonData.products.length > 0) {",
							"    pm.collectionVariables.set(\"productId\", jsonData.products[0].id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{host}}/api/v1/catalogs/{{catalogId}}?expand=products",
					"host": [
						"{{host}}"
					],
					"path": [
