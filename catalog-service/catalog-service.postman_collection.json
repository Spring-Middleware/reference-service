			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"products\": [\n    {\n      \"name\": \"Beach Towel\",\n      \"sku\": \"TOWEL-001\",\n      \"price\": {\n        \"amount\": 15.50,\n        \"currency\": \"EUR\"\n      },\n      \"status\": \"ACTIVE\"\n    },\n    {\n      \"name\": \"Sun Hat\",\n      \"sku\": \"HAT-001\",\n      \"price\": {\n        \"amount\": 12.00,\n        \"currency\": \"EUR\"\n      },\n      \"status\": \"ACTIVE\"\n    }\n  ]\n}"
